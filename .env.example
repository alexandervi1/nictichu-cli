# NictichuCLI - Variables de entorno
# Copia este archivo como .env y configura tus API keys

# ============================================================
# PROVEEDORES DE MODELO (elige uno o varios)
# ============================================================

# --- Opcion 1: Ollama (local, gratuito, requiere PC con 8GB+ RAM) ---
# 1. Instala Ollama: https://ollama.com
# 2. Descarga un modelo: ollama pull gemma4:e2b
# 3. No necesitas API key, Ollama corre localmente
OLLAMA_BASE_URL=http://localhost:11434

# --- Opcion 2: Google AI Studio (cloud, gratuito, sin instalar nada) ---
# 1. Obten tu API key GRATIS en: https://aistudio.google.com/apikey
# 2. Pega tu key abajo
# 3. Ejecuta con: python -m src.main interactive -p google_ai -m gemini-2.0-flash
GOOGLE_AI_API_KEY=

# Modelos disponibles (gratis):
#   gemini-2.0-flash      - Rapido y gratuito (RECOMENDADO)
#   gemini-2.5-flash      - Mas preciso, aun gratuito
#   gemini-2.5-pro        - Maxima calidad

# --- Opcion 3: Vertex AI (cloud, requiere Google Cloud) ---
# GOOGLE_CLOUD_PROJECT=tu_proyecto_id
# GOOGLE_CLOUD_LOCATION=us-central1

# ============================================================
# CONFIGURACION GENERAL
# ============================================================
LOG_LEVEL=INFO